# Wallet Birthday - Environment Variables

# Etherscan API Key (optional, speeds up scanning)
# Get free key at: https://etherscan.io/myapikey
VITE_ETHERSCAN_API_KEY=

# Base Mainnet RPC (optional, fallback to public)
VITE_BASE_RPC_URL=

# WalletConnect Project ID (optional)
VITE_WALLETCONNECT_PROJECT_ID=

# For deployment
PRIVATE_KEY=
BASESCAN_API_KEY=
